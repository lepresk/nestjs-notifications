{
  "name": "@lepresk/nestjs-notifications",
  "version": "0.1.0",
  "description": "A small, type-safe notification engine for NestJS in the spirit of Laravel notifications: pluggable channels, per-recipient preference filtering, background and after-commit delivery, generic over your own channel and preference-group types.",
  "keywords": [
    "nestjs",
    "notifications",
    "laravel",
    "channels",
    "mail",
    "in-app",
    "preferences",
    "after-commit",
    "transactional",
    "typescript"
  ],
  "license": "MIT",
  "author": "lepresk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lepresk/nestjs-notifications.git"
  },
  "bugs": {
    "url": "https://github.com/lepresk/nestjs-notifications/issues"
  },
  "homepage": "https://github.com/lepresk/nestjs-notifications#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
